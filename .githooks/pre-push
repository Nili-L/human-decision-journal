#!/usr/bin/env bash
# Backstop: never push the journal file to the PUBLIC upstream remote.
set -euo pipefail
remote_name="$1"
remote_url="${2:-}"
case "$remote_name" in upstream) blocked=1 ;; *) blocked=0 ;; esac
case "$remote_url" in *human-decision-journal*) blocked=1 ;; esac
[ "$blocked" -eq 0 ] && exit 0
if git diff --name-only @{push}.. 2>/dev/null | grep -qx "DECISIONS_JOURNAL.md"; then
  echo "pre-push: refusing to push DECISIONS_JOURNAL.md to '$remote_name' (public)." >&2
  exit 1
fi
exit 0
